# -----------------------------------------------------------------------------
# CRMIT Backend Environment Template
# -----------------------------------------------------------------------------
# Copy to: backend/.env
# IMPORTANT:
# - Never commit real secrets/keys.
# - For packaged Desktop/EXE builds, you can also place this at:
#   %APPDATA%\BioVaram\.env (Windows)
# -----------------------------------------------------------------------------

# Environment
CRMIT_ENV=development
# Back-compat: Settings reads CRMIT_ENVIRONMENT; CRMIT_ENV is accepted via aliasing.
CRMIT_ENVIRONMENT=development

# Debug
CRMIT_DEBUG=true

# Database
# Official: CRMIT_DATABASE_URL (recommended). Alias supported: CRMIT_DB_URL
CRMIT_DATABASE_URL=sqlite+aiosqlite:///./data/crmit.db
CRMIT_DB_URL=sqlite+aiosqlite:///./data/crmit.db
# For PostgreSQL (production/server):
# CRMIT_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/crmit_db

# File Storage
CRMIT_UPLOAD_DIR=data/uploads
CRMIT_PARQUET_DIR=data/parquet
CRMIT_TEMP_DIR=data/temp
CRMIT_MAX_UPLOAD_SIZE=100

# CORS
CRMIT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# Security
CRMIT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_SECURE_RANDOM_KEY

# Processing
CRMIT_MAX_WORKERS=4
CRMIT_TASK_TIMEOUT_SECONDS=300

# Quality Control
CRMIT_QC_MIN_EVENTS_FCS=1000
CRMIT_QC_TEMP_MIN_CELSIUS=15.0
CRMIT_QC_TEMP_MAX_CELSIUS=25.0

# -----------------------------------------------------------------------------
# AI Configuration
# -----------------------------------------------------------------------------
# Offline fallback (recommended ON for dev/testing UI without credentials)
# CRMIT_ENABLE_OFFLINE_AI=true
# To force real AI calls and fail fast when keys are missing:
# CRMIT_ENABLE_OFFLINE_AI=false

# AI Provider: bedrock | openai | anthropic
AI_PROVIDER=bedrock

# Hosted AI Gateway (recommended for desktop/EXE distribution)
# Desktop/EXE mode:
# - set AI_PROVIDER=gateway
# - set CRMIT_AI_GATEWAY_URL to your hosted gateway base URL
# - set CRMIT_AI_GATEWAY_LICENSE_KEY to the client-specific license key
CRMIT_AI_GATEWAY_URL=
CRMIT_AI_GATEWAY_LICENSE_KEY=

# Gateway server mode (hosted): optional allow-list. If set, requests must include X-License-Key.
# Comma-separated list of valid keys.
CRMIT_AI_GATEWAY_LICENSE_KEYS=

# AWS Bedrock (only needed for real AI calls)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Optional (if using OpenAI/Anthropic instead of Bedrock)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
